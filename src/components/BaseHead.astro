---
import { SEO } from 'astro-seo';
import { SITE } from '../consts';

import '../styles/variable.css';
import '../styles/component.css';
import '../styles/hover.css';
import '../styles/media.css';
import '../styles/global.css';
import '../styles/markdown.css';
import '../styles/layout.css';
import '../styles/postPage.css';
import '../styles/blogPage.css';

const {
	title = SITE.title,
	description = SITE.desc,
	ogImage = SITE.ogImage,
	ogType = SITE.ogType,
	twitterCard = SITE.twitterCard,
	robots = SITE.robots,
	url = Astro.url,
	useResetCss = true
} = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="robots" content={robots} />

<SEO
	title={title}
	description={description}
	openGraph={{
		basic: {
			title,
			type: ogType,
			image: '/og.png',
			url: url
		},
		optional: {
			siteName: title,
			description,
			locale: 'ko'
		}
	}}
	twitter={{
		image: ogImage,
		imageAlt: title,
		title,
		description,
		card: twitterCard
	}}
/>

{useResetCss && <link rel="stylesheet" href="/styles/common/reset.css" />}

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple/apple.icon.png" />
<meta name="msapplication-TileColor" content="#FFFFFF" />
<meta name="theme-color" content="#ffffff" />

<link
	rel="stylesheet"
	as="style"
	crossorigin
	href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
/>

<link
	rel="stylesheet"
	href="https://cdnjs.cloudflare.com/ajax/libs/github-markdown-css/5.2.0/github-markdown-light.css"
	integrity="sha512-n5zPz6LZB0QV1eraRj4OOxRbsV7a12eAGfFcrJ4bBFxxAwwYDp542z5M0w24tKPEhKk2QzjjIpR5hpOjJtGGoA=="
	crossorigin="anonymous"
	referrerpolicy="no-referrer"
/>