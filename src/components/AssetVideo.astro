---
const { src, type = 'video/mp4', ...rest } = Astro.props;

const base = import.meta.env.PUBLIC_ASSETS_BASE_URL;

function toRelativeAssetPath(value = '') {
	return value.replace(/^\//, '');
}

function isAbsoluteOrExternalPath(value = '') {
	return /^(?:[a-z]+:|\/|#)/i.test(value);
}

const url = !base || isAbsoluteOrExternalPath(src)
	? src
	: new URL(toRelativeAssetPath(src), base).toString();
---

<video controls {...rest}>
	<source src={url} type={type} />
	브라우저가 video 태그를 지원하지 않습니다.
</video>
