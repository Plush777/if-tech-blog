---
const { src, alt, width, height, className, type = 'hero' } = Astro.props;

function getImageClassName(type: string) {
	if (type === 'hero') return 'rounded-none';
	if (type === 'thumbnail') return 'rounded-[12px_12px_0_0]';

	return '';
}

const base = import.meta.env.PUBLIC_ASSETS_BASE_URL;

function resolveImageUrl(value: string) {
	if (!value) {
		return value;
	}

	if (!base) {
		return value;
	}

	return new URL(value, base).toString();
}

const resolvedSrc = resolveImageUrl(src);
---

<img
	src={resolvedSrc}
	alt={alt}
	width={width}
	height={height}
	className={`${className} ${getImageClassName(type)}`}
/>
